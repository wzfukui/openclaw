{
  "name": "@wzfukui/openclaw-ani",
  "version": "2026.5.9",
  "description": "ANI Agent-Native IM channel plugin",
  "type": "module",
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "openclaw": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "ani",
      "label": "Agent-Native IM",
      "selectionLabel": "Agent-Native IM (ANI)",
      "docsPath": "/channels/ani",
      "docsLabel": "ani",
      "blurb": "Agent-Native IM — messaging built for AI-first Bot collaboration.",
      "order": 80,
      "quickstartAllowFrom": false
    },
    "install": {
      "npmSpec": "@wzfukui/openclaw-ani",
      "localPath": "extensions/ani",
      "defaultChoice": "npm"
    },
    "compat": {
      "pluginApi": ">=2026.5.4"
    },
    "build": {
      "openclawVersion": "2026.5.4"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
